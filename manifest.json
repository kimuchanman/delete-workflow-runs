{
  "manifest_version": 3,
  "name": "Delete All Workflow Runs",
  "version": "1.0.0",
  "description": "Delete all GitHub Actions workflow runs with one click",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/actions/workflows/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
